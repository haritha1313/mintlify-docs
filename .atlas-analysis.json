  "keyFeatures": [
    "Production-like isolated sandbox environments for repeatable agent runs",
    "Multi-agent support: Claude Code, Codex, Cursor, GitHub Copilot, and more",
    "Controlled variable experiments across agents, models, treatments, and versions",
    "Full trajectory capture: tool calls, tokens, diffs, errors, and reasoning hooks",
    "Automated rubric evaluation with best-practice rewrites",
    "CI/CD integration to gate releases on agent workflow quality",
    "Scheduled drift detection for model and dependency changes",
    "Comparative metrics across runs: steps, tokens, cost, duration, frictions",
    "Export and API access for trace data and results",
    "100 free runs to get started"
  ],
  "publicApiSurface": [
    "Experiment definition (workflow, treatment, agents, configuration)",
    "Sandbox execution (local and cloud environments)",
    "Trial management (parallel runs, trial count)",
    "Rubric and validator configuration",
    "Trace export (traces.jsonl)",
    "Results API (metrics, diffs, evals outcome)",
    "CI/CD hooks (pull_request, schedule triggers)",
    "Library (repos + data fixtures)",
    "Agent browser (GUI and CLI modes)"
  ]
